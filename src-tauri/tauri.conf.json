{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "아웃리치 회계",
  "version": "0.1.3",
  "identifier": "org.onnuri.accounting-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "아웃리치 회계",
        "width": 1440,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https:; worker-src 'self' blob:; script-src 'self' 'unsafe-eval'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/accounting-template.xlsx"
    ],
    "category": "Finance",
    "shortDescription": "회계보고서와 영수증철을 로컬에서 작성합니다.",
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwQTMwNjVDMzdDQTJFOTcKUldTWExzbzNYQWFqb014QjNMOTVJcHdkSFZkSHg2U1JqSlVuWTVrRm5OOHp5RWl0TzVvSWZKVmIK",
      "endpoints": [
        "https://github.com/Tangeroooo/accounting-assistant/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
